# =============================================================================
# Insurance Policy R&D System — Environment Configuration
# Microsoft Agent Framework + CodeAct + Gemini
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values for your chosen authentication mode below.
#   3. Never commit .env to source control — it is in .gitignore.
# =============================================================================


# =============================================================================
# AUTHENTICATION MODE — choose ONE of the two sections below
# =============================================================================

# -----------------------------------------------------------------------------
# OPTION A: Gemini Developer API  (recommended for local development)
#   1. Visit https://aistudio.google.com/apikey
#   2. Sign in with your Google account
#   3. Click "Create API key"
#   4. Paste the key below
# -----------------------------------------------------------------------------

GEMINI_API_KEY=your-google-ai-studio-api-key-here

# Alternative name also accepted by GeminiChatClient (either works):
# GOOGLE_API_KEY=your-google-ai-studio-api-key-here


# -----------------------------------------------------------------------------
# OPTION B: Vertex AI  (for GCP / enterprise use)
#   1. Enable the Vertex AI API in your GCP project
#   2. Run:  gcloud auth application-default login
#   3. Uncomment and fill in the three variables below
#   4. Comment out GEMINI_API_KEY above
# -----------------------------------------------------------------------------

# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1


# =============================================================================
# MODEL SELECTION
# =============================================================================
# Accepted by GeminiChatClient as GEMINI_MODEL or GOOGLE_MODEL (either works).
#
# Recommended models (as of 2026-07):
#
#   gemini-2.5-flash-lite   — fastest, lowest cost, good for demos       (DEFAULT)
#   gemini-2.5-flash        — balanced speed/quality, strong tool-calling
#   gemini-2.5-pro          — highest quality, best for complex reasoning
#   gemini-2.0-flash        — previous generation flash, stable
#
# CodeAct note: models must support function/tool calling.
# All gemini-2.0+ and gemini-2.5+ variants support this.
# =============================================================================

GEMINI_MODEL=gemini-2.5-flash-lite

# Alternative name also accepted (either works):
# GOOGLE_MODEL=gemini-2.5-flash-lite


